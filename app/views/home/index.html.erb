<% content_for :title, "Mydinnertime" %>

<section class="home-page">
  <div class="home-shell" data-controller="ingredient-tags" data-ingredient-tags-initial-tags-value="<%= json_escape(@ingredients.to_json) %>">
    <header class="hero panel">
        <div>
          <p class="panel-label">Recipe matching by ingredients</p>
          <h1>MyDinnerTime</h1>
        </div>
        <div class="hero-badge">
          <span>Selected ingredients</span>
          <strong data-ingredient-tags-target="count">0</strong>
        </div>
      </header>

      <%= form_with url: root_path, method: :get, class: "home-content", data: { ingredient_tags_target: "form" } do %>
        <section class="panel">
          <label for="ingredients-input" class="field-label">Ingredients</label>
          <p class="field-help">Type at least 3 characters. Use Tab or comma to add an ingredient, then press Enter to search.</p>
          <div class="tag-field" data-action="click->ingredient-tags#focusInput">
            <div class="chips" data-ingredient-tags-target="chips"></div>
            <input
              id="ingredients-input"
              class="tag-input"
              type="text"
              placeholder="e.g. tomato, garlic, chicken"
              minlength="3"
              autocomplete="off"
              data-ingredient-tags-target="input"
              data-action="keydown->ingredient-tags#handleKeydown blur->ingredient-tags#handleBlur"
            >
          </div>

          <div class="actions">
            <button type="button" class="action-button clear-button" data-action="click->ingredient-tags#clearAll">
              Clear all
            </button>

            <button
              type="submit"
              class="action-button search-button"
              data-ingredient-tags-target="submit"
              <%= "disabled" if @ingredients.empty? %>
            >
              Search Recipe
            </button>
          </div>
        </section>

        <section class="panel">
          <h2>Recipes</h2>
          <% if @recipes.empty? %>
            <div class="results-placeholder">Recipe cards will appear here after search.</div>
          <% else %>
            <div class="recipe-list">
              <% @recipes.each do |result| %>
                <article class="recipe-card" data-controller="recipe-card" data-expanded="false">
                  <img
                    src="<%= result.recipe.image_url %>"
                    alt="<%= result.recipe.title %>"
                    class="recipe-image"
                  >

                  <div class="recipe-body">
                    <div class="recipe-meta">
                      <h3><%= result.recipe.title %></h3>

                      <div class="recipe-badges">
                        <span class="recipe-badge"><%= result.matched_count %> match<%= "es" unless result.matched_count == 1 %></span>
                        <span class="recipe-badge">Rating <%= number_with_precision(result.recipe.ratings || 0, precision: 1) %></span>
                      </div>
                    </div>

                    <div class="recipe-ingredients">
                      <% result.ingredients.each do |item| %>
                        <span class="recipe-ingredient <%= "is-match" if @selected_ingredient_names.any? { |name| item.ingredient.name.include?(name) } %>">
                          <%= item.ingredient.name %>
                        </span>
                      <% end %>
                    </div>

                    <button type="button" class="recipe-toggle" data-action="recipe-card#toggle" data-recipe-card-target="toggle" aria-expanded="false">
                      <span data-recipe-card-target="toggleLabel">Show details</span>
                    </button>

                    <div class="recipe-details" data-recipe-card-target="details" hidden>
                      <div class="recipe-detail-grid">
                        <% if result.recipe.author.present? %>
                          <div class="recipe-detail-item">
                            <span class="recipe-detail-label">Author</span>
                            <strong><%= result.recipe.author %></strong>
                          </div>
                        <% end %>

                        <% if result.recipe.category.present? %>
                          <div class="recipe-detail-item">
                            <span class="recipe-detail-label">Category</span>
                            <strong><%= result.recipe.category %></strong>
                          </div>
                        <% end %>

                        <% if result.recipe.cuisine.present? %>
                          <div class="recipe-detail-item">
                            <span class="recipe-detail-label">Cuisine</span>
                            <strong><%= result.recipe.cuisine %></strong>
                          </div>
                        <% end %>

                        <% if result.recipe.prep_time.present? %>
                          <div class="recipe-detail-item">
                            <span class="recipe-detail-label">Prep time</span>
                            <strong><%= result.recipe.prep_time %> min</strong>
                          </div>
                        <% end %>

                        <% if result.recipe.cook_time.present? %>
                          <div class="recipe-detail-item">
                            <span class="recipe-detail-label">Cook time</span>
                            <strong><%= result.recipe.cook_time %> min</strong>
                          </div>
                        <% end %>
                      </div>

                      <div class="recipe-preparation">
                        <h4>Preparation</h4>
                        <ol class="recipe-preparation-list">
                          <% result.preparation_lines.each do |item| %>
                            <li><%= item.preparation %></li>
                          <% end %>
                        </ol>
                      </div>
                    </div>
                  </div>
                </article>
              <% end %>
            </div>
          <% end %>
        </section>
    <% end %>
  </div>
</section>
